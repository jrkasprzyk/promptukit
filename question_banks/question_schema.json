{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PromptuKit Question Bank",
  "description": "Schema for question banks consumable by promptukit.create_exam",
  "oneOf": [
    {
      "type": "object",
      "properties": {
        "sections": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "title": { "type": "string" },
              "name": { "type": "string" },
              "label": { "type": "string" },
              "questions": {
                "type": "array",
                "items": { "$ref": "#/definitions/question" }
              }
            },
            "additionalProperties": true
          }
        },
        "categories": { "$ref": "#/properties/sections" }
      },
      "additionalProperties": true
    },
    {
      "type": "object",
      "properties": {
        "questions": {
          "type": "array",
          "items": { "$ref": "#/definitions/question" }
        }
      },
      "additionalProperties": true
    },
    {
      "type": "array",
      "items": { "$ref": "#/definitions/question" }
    }
  ],
  "definitions": {
    "question": {
      "type": "object",
      "properties": {
        "q": { "type": "string" },
        "prompt": { "type": "string" },
        "question": { "type": "string" },
        "text": { "type": "string" },
        "choices": { "type": "array", "items": { "type": "string" } },
        "answers": { "type": "array", "items": { "type": "string" } },
        "category": { "type": "string" }
      },
      "additionalProperties": true
    }
  }
}
