@@ -0,0 +1,86 @@
+"""Minimal Python-side PromptuKit example called from MATLAB.
+
+This file demonstrates a lightweight interoperability boundary:
+
+- MATLAB owns the numerical workflow and passes scalar results to Python.
+- Python uses PromptuKit's question model and validation utilities to create a
+  structured, PromptuKit-compatible question bank.
+
+The script can also be run directly from Python. In that case, it uses fallback
+values and prints the generated JSON question bank.
+"""
+
+from __future__ import annotations
+
+import json
+
+from promptukit.questions.question_models import Calculation
+from promptukit.questions.validate_question import validate
+
+
+# MATLAB passes these names into the script through pyrunfile. When the script is
+# run directly from Python, provide fallback values so the example remains easy
+# to smoke-test without MATLAB.
+try:
+    flow_mgd
+except NameError:
+    flow_mgd = 125.4
+
+try:
+    cost_usd
+except NameError:
+    cost_usd = 8.91e6
+
+try:
+    reliability
+except NameError:
+    reliability = 0.93
+
+
+unit_cost = float(cost_usd) / float(flow_mgd)
+
+question = Calculation(
+    text=(
+        "A water-system design has a capacity of "
+        f"{float(flow_mgd):.1f} MGD and a total cost of "
+        f"${float(cost_usd):,.0f}. What is the unit cost in dollars per MGD?"
+    ),
+    answer=unit_cost,
+    tolerance=max(unit_cost * 0.005, 1.0),
+    unit="USD/MGD",
+).to_dict()
+
+# Add fields required by PromptuKit's question-bank validator.
+question.update(
+    {
+        "id": "matlab_water_design_unit_cost",
+        "category": "water resources",
+        "difficulty": "medium",
+        "metadata": {
+            "source": "examples/matlab",
+            "flow_mgd": float(flow_mgd),
+            "cost_usd": float(cost_usd),
+            "reliability": float(reliability),
+        },
+    }
+)
+
+question_bank = {
+    "categories": ["water resources"],
+    "questions": [question],
+}
+
+errors, warnings = validate(question_bank)
+if errors:
+    raise ValueError("Generated PromptuKit question bank is invalid: " + "; ".join(errors))
+
+question_bank_json = json.dumps(
+    {
+        **question_bank,
+        "_validation": {
+            "errors": errors,
+            "warnings": warnings,
+        },
+    },
+    indent=2,
+)
+
+
+if __name__ == "__main__":
+    print(question_bank_json)
